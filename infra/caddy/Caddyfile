{$DOMAIN} {
    encode gzip

    @multiplayer_ws path /multiplayer /multiplayer/* /spectate /spectate/*
    reverse_proxy @multiplayer_ws multiplayer:5001

    @community_api path /api/community* /socket.io*
    reverse_proxy @community_api community-api:7000

    @community_web path /community* /admin* /_next*
    reverse_proxy @community_web community-web:3000

    # Everything else goes to the classic game / platform server
    reverse_proxy web:8080
}
